<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Application identifier (Team ID + Bundle ID) -->
    <key>com.apple.application-identifier</key>
    <string>TXN399AHT5.com.app.memosa</string>

    <!-- Team identifier -->
    <key>com.apple.developer.team-identifier</key>
    <string>TXN399AHT5</string>

    <!-- Required for Mac App Store submission -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Microphone access (recording) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Network: outbound — required to download Whisper speech-recognition models from HuggingFace on first use,
         and (optionally) to reach Google Calendar / a cloud insight provider when the user opts in -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Network: inbound (loopback only) — the Google Calendar OAuth flow runs a transient
         localhost:8899 callback listener to capture the redirect; required under the sandbox -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- User-selected file access (storage folder picker, export) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Persist access to user-selected storage folder across relaunches -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
